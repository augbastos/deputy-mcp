# deputy-mcp configuration — copy to `.env` and fill in your values.
# Never commit the real `.env`; it holds a secret.
# The server loads this automatically from the working directory, or from the
# path in DEPUTY_ENV_FILE. Real environment variables always take precedence.
#
# Pick ONE of the two modes below.

# ─────────────────────────────────────────────────────────────────────────────
# MODE A — API token (full: roster, timesheets, team, areas, and opt-in writes)
# Needs an admin/System-Administrator access level to create the token.
# ─────────────────────────────────────────────────────────────────────────────

# Deputy API token (permanent token or OAuth access token).
# Create it in Deputy: Business settings -> Integrations ->
# /exec/devapp/oauth_clients -> New OAuth Client -> Get an Access Token (shown once).
DEPUTY_API_TOKEN=your-deputy-api-token-here

# Your Deputy install base URL — the address you see when logged in.
# Pattern: https://{install}.{geo}.deputy.com (geo is your region, e.g. au, eu, uk, us/na).
# A trailing slash or an "/api/v1" suffix is accepted and normalized away.
DEPUTY_BASE_URL=https://your-company.eu.deputy.com

# ─────────────────────────────────────────────────────────────────────────────
# MODE B — iCal calendar feed (roster only, NO API token, works for any employee)
# Use this when you can't create an API token (e.g. you're not a Deputy admin).
# In Deputy, open My Schedule and copy your "Subscribe / Export to calendar" link,
# then paste it here and leave DEPUTY_API_TOKEN / DEPUTY_BASE_URL above unset.
# This URL is a secret (it contains your personal feed token) — never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# DEPUTY_CALENDAR_URL=https://your-company.eu.deputy.com/exec/ical/xxxxxxxx/My_Roster.ics

# ─────────────────────────────────────────────────────────────────────────────
# Optional settings (apply to whichever mode is active)
# ─────────────────────────────────────────────────────────────────────────────

# Allow a DEPUTY_BASE_URL host outside *.deputy.com (enterprise custom domains only).
# Off by default: an unrecognised host fails closed so a typo can't point your token
# at an unintended server. Accepts true/1/yes. Default: false.
DEPUTY_ALLOW_CUSTOM_HOST=false

# Enable write tools (clock in/out, claim shift, swap, unavailability). API mode only.
# Off by default; write tools are hidden while this is false. Accepts true/1/yes.
DEPUTY_ALLOW_WRITES=false

# In-memory read cache lifetime in seconds. 0 disables caching. Default: 30.
DEPUTY_CACHE_TTL=30

# Per-request HTTP timeout in seconds. Default: 30.
DEPUTY_TIMEOUT=30

# Max automatic retries on 429/5xx/transport errors (with backoff). Default: 3.
DEPUTY_MAX_RETRIES=3
