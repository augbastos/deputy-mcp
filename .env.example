# deputy-mcp configuration — copy to `.env` and fill in your values.
# Never commit the real `.env`; it holds a secret token.

# Required. Deputy API token (permanent token or OAuth access token).
# Create a permanent token in Deputy: Business settings -> Integrations ->
# /exec/devapp/oauth_clients -> New OAuth Client -> Get an Access Token (shown once).
DEPUTY_API_TOKEN=your-deputy-api-token-here

# Required. Your Deputy install base URL — the address you see when logged in.
# Pattern: https://{install}.{geo}.deputy.com (geo is your region, e.g. au, eu, uk, us/na).
# A trailing slash or an "/api/v1" suffix is accepted and normalized away.
DEPUTY_BASE_URL=https://your-company.eu.deputy.com

# Optional. Enable write tools (clock in/out, claim shift, swap, unavailability).
# Off by default for safety; write tools are hidden while this is false.
# Accepts true/1/yes (case-insensitive). Default: false.
DEPUTY_ALLOW_WRITES=false

# Optional. In-memory read cache lifetime in seconds. 0 disables caching. Default: 30.
DEPUTY_CACHE_TTL=30

# Optional. Per-request HTTP timeout in seconds. Default: 30.
DEPUTY_TIMEOUT=30

# Optional. Max automatic retries on 429/5xx/transport errors (with backoff). Default: 3.
DEPUTY_MAX_RETRIES=3
